# Copia este ficheiro para ".env" e preenche com as TUAS chaves.
# O ficheiro .env está no .gitignore e NUNCA deve ser partilhado/versionado.

# context.dev — motor de scraping hospedado (Bearer token)
# A chave começa por "ctxt_secret_". Gera uma nova em https://www.context.dev/
CONTEXT_DEV_API_KEY=

# OpenRouter — extração de campos com IA
# A chave começa por "sk-or-". Gera em https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Modelo a usar (barato e bom para extração estruturada). Podes trocar.
OPENROUTER_MODEL=openai/gpt-4o-mini

# País para o context.dev (geolocalização do pedido). PT = Portugal.
SCRAPE_COUNTRY=pt

# --------------------------------------------------------------------------- #
# Descoberta via Google (fonte "google") — API de pesquisa Serper.dev.
# Não raspa o Google diretamente (ToS/captcha); usa esta API. Gera em serper.dev
SEARCH_API_KEY=
SEARCH_COUNTRY=pt

# --------------------------------------------------------------------------- #
# Idealista via APIFY (fonte "idealista"). O Idealista tem DataDome; usamos um
# ator do Apify em vez de scraping direto. ⚠️ CRÉDITO LIMITADO — controla o custo
# com APIFY_IDEALISTA_MAX (teto de itens por corrida).
APIFY_TOKEN=
APIFY_IDEALISTA_ACTOR=            # ex.: igolaizola~idealista-scraper  (username~ator)
APIFY_IDEALISTA_MAX=20
# Opcional: se o ator exigir outro schema de input, cola aqui o JSON de input.
# APIFY_IDEALISTA_INPUT={"location":"portugal","maxItems":20}

# --------------------------------------------------------------------------- #
# Facebook Marketplace via Apify (fonte "facebook") — a MELHOR fonte FSBO da
# Madeira (Marketplace = particulares). Usa o MESMO APIFY_TOKEN acima; NÃO
# arrisca a tua conta de Facebook. Localiza por ID de zona (não por nome):
# abre o Marketplace na zona e copia o número do URL /marketplace/<id>/.
APIFY_FB_LOCATION=110189845667755    # default: Funchal, Madeira
APIFY_FB_MAX=30                      # teto de anúncios por corrida (custo)
APIFY_FB_DETAILS=1                   # 1 = traz descrição+fotos (telefone quando existe)
